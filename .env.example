# =============================================================================
# Sydney Commute Affordability Report — Environment Configuration Template
# =============================================================================
#
# Copy this file to configure local development. Never commit real secrets.
#
# DEPLOYMENT SPLIT
# ----------------
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ Vercel (frontend/)     Public VITE_* vars — baked into the static build │
# │ GitHub Actions (ETL)   Private secrets — repository Settings → Secrets  │
# │ Local backend dev      backend/.env — FastAPI + standalone ETL scripts  │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Quick start (local):
#   cp .env.example backend/.env
#   cp .env.example frontend/.env
#   Fill in values below, then run scripts/dev.sh or start services separately.
#
# =============================================================================


# =============================================================================
# VERCEL — Public frontend variables (safe to expose in browser bundle)
# Configure in: Vercel Project → Settings → Environment Variables
# =============================================================================

# Supabase REST — anon key only; Row Level Security must protect write paths
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# MapTiler Cloud — basemap tiles (restrict key to your Vercel domain in MapTiler)
VITE_MAPTILER_API_KEY=your_maptiler_key_here

# Optional: legacy FastAPI base URL when running full-stack locally (not used on Vercel static deploy)
VITE_API_BASE_URL=http://localhost:8000


# =============================================================================
# GITHUB ACTIONS — Private ETL pipeline secrets (never expose to Vercel)
# Configure in: GitHub Repository → Settings → Secrets and variables → Actions
# =============================================================================

# Supabase — service_role key recommended for server-side bulk inserts
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# TfNSW Open Data — JWT for Trip Planner multimodal API
TFNSW_API_KEY=your_tfnsw_jwt_here

# OpenRouteService — driving routes and distance (stored as OPENROUTESERVICE_KEY in GitHub;
# mapped to OPENROUTESERVICE_API_KEY at runtime by .github/workflows/run_etl.yml)
OPENROUTESERVICE_API_KEY=your_ors_key_here


# =============================================================================
# LOCAL BACKEND — FastAPI app and ad-hoc ETL runs (backend/.env)
# Not required for Vercel static deploy or GitHub Actions when secrets are set in CI
# =============================================================================

# MapTiler Cloud — server-side driving routes (if using FastAPI travel endpoints)
MAPTILER_API_KEY=your_maptiler_key_here

# NSW FuelCheck — live fuel prices for car cost engine (optional; ETL falls back without these)
FUELCHECK_API_KEY=your_nsw_api_key_here
FUELCHECK_API_SECRET=your_nsw_api_secret_here
FUELCHECK_API_VERSION=v1

# SQLite persistence for API response cache (local MVP only)
DATABASE_URL=sqlite:///./data/commute_compare.db
CACHE_TTL_HOURS=24
